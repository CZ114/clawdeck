{
  "name": "vibelog",
  "version": "1.4.1",
  "private": true,
  "description": "vibelog — background-watch your Claude Code agent, then review what it taught you the next day.",
  "author": "CZ114",
  "homepage": "https://github.com/CZ114/vibelog",
  "repository": {
    "type": "git",
    "url": "https://github.com/CZ114/vibelog.git"
  },
  "main": "packages/desktop/main.js",
  "scripts": {
    "daemon": "node packages/daemon/src/index.js",
    "approve": "node scripts/decide.js approve",
    "deny": "node scripts/decide.js deny",
    "answer": "node scripts/decide.js answer",
    "setup-hooks": "node scripts/setup-hooks.js",
    "setup-user-hooks": "node scripts/setup-user-hooks.js",
    "doctor": "node scripts/doctor.js",
    "desktop": "electron packages/desktop/main.js",
    "smoke": "node scripts/smoke-test.js",
    "render-demos": "node scripts/render-demos.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win"
  },
  "engines": {
    "node": ">=20"
  },
  "build": {
    "appId": "io.vibelog.app",
    "productName": "vibelog",
    "copyright": "© 2026 vibelog",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "packages/**/*",
      "scripts/lib/**/*",
      "package.json",
      "!packages/hooks/**",
      "!**/*.{md,test.js,spec.js}",
      "!**/.{git,idea,vscode}",
      "!**/{__tests__,test,tests,coverage,docs,examples}"
    ],
    "afterPack": "scripts/after-pack.js",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "vibelog",
      "uninstallDisplayName": "vibelog",
      "artifactName": "${productName}-${version}.exe",
      "include": "build/installer.nsh"
    }
  },
  "devDependencies": {
    "electron": "^41.4.0",
    "electron-builder": "^25.1.8",
    "playwright": "^1.49.0",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2"
  }
}
