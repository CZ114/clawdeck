{
  "name": "clawdeck",
  "version": "0.0.0",
  "private": true,
  "description": "Clawdeck — a floating Windows desktop companion for Claude Code approvals, sessions, and status. iPhone companion planned.",
  "scripts": {
    "daemon": "node packages/daemon/src/index.js",
    "hook:event": "node packages/hooks/event.js",
    "hook:pre-tool-use": "node packages/hooks/pre-tool-use.js",
    "hook:permission-request": "node packages/hooks/permission-request.js",
    "approve": "node scripts/decide.js approve",
    "deny": "node scripts/decide.js deny",
    "answer": "node scripts/decide.js answer",
    "setup-hooks": "node scripts/setup-hooks.js",
    "setup-user-hooks": "node scripts/setup-user-hooks.js",
    "doctor": "node scripts/doctor.js",
    "desktop": "electron packages/desktop/main.js",
    "smoke": "node scripts/smoke-test.js",
    "render-demos": "node scripts/render-demos.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "electron": "^41.4.0",
    "playwright": "^1.49.0"
  }
}
